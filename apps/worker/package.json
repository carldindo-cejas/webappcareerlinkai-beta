{
    "name": "careerlinkai-worker",
    "version": "1.0.0",
    "private": true,
    "main": "src/index.ts",
    "scripts": {
        "dev": "wrangler dev --remote",
        "deploy": "wrangler deploy",
        "typecheck": "tsc",
        "test": "vitest run",
        "test:watch": "vitest",
        "ml:build-map": "node ./scripts/build-predictor-map.mjs",
        "db:init": "wrangler d1 execute DB --remote --file=./schema.sql",
        "db:init:remote": "wrangler d1 execute DB --remote --file=./schema.sql"
    },
    "dependencies": {
        "hono": "^4.6.10",
        "jose": "^5.9.6"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^4.20241106.0",
        "typescript": "^5.6.3",
        "vitest": "^2.1.8",
        "wrangler": "^4.83.0"
    }
}